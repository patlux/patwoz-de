---
interface Props {
  lang?: 'en' | 'de'
}

type App = {
  name: string
  href: string
  icon: string
  description: string
  external?: boolean
}

const { lang = 'en' } = Astro.props
const isGerman = lang === 'de'
const basePath = isGerman ? '/de' : ''
const apps: App[] = [
  {
    name: 'KulturPass DE',
    href: `${basePath}/work/kulturpass`,
    icon: '/apps/kulturpass.png',
    description: isGerman ? 'Kulturmarktplatz' : 'Culture marketplace',
  },
  {
    name: 't-online',
    href: `${basePath}/work/stroeer`,
    icon: '/apps/t-online.jpg',
    description: isGerman ? 'Nachrichten-App' : 'News app',
  },
  {
    name: 'Football was my first love',
    href: `${basePath}/work/kicker`,
    icon: '/apps/football-was-my-first-love.jpg',
    description: isGerman ? 'Fußball-Audio' : 'Football audio',
  },
  {
    name: 'ABL Configuration',
    href: `${basePath}/work/abl`,
    icon: '/apps/abl-configuration.jpg',
    description: isGerman ? 'Wallbox-Konfiguration' : 'Wallbox configuration',
  },
  {
    name: 'Meine BARMER',
    href: `${basePath}/work/ibm`,
    icon: '/apps/meine-barmer.jpg',
    description: isGerman ? 'Gesundheits-App' : 'Healthcare app',
  },
  {
    name: 'Enerparc ESS',
    href: 'https://www.enerparc.de',
    icon: '/apps/enerparc-ess.png',
    description: isGerman ? 'Energy-Service' : 'Energy service',
    external: true,
  },
  {
    name: 'Finanzguru',
    href: 'https://apps.apple.com/de/app/finanzguru-konten-vertr%C3%A4ge/id1214803607',
    icon: '/apps/finanzguru.jpg',
    description: isGerman ? 'Finanz-App' : 'Finance app',
    external: true,
  },
  {
    name: 'Yuu Yoga',
    href: 'https://apps.apple.com/de/app/yuu-yoga-yoga-neu-erleben/id1540962781',
    icon: '/apps/yuu-yoga.jpg',
    description: 'Yoga',
    external: true,
  },
  {
    name: 'kaarst lokal',
    href: 'https://apps.apple.com/de/app/kaarst-lokal/id6746488444',
    icon: '/apps/kaarst-lokal.jpg',
    description: isGerman ? 'Lokaler Handel' : 'Local commerce',
    external: true,
  },
  {
    name: 'Glowing Blox',
    href: 'https://play.google.com/store/apps/details?id=tech.piparo.glowingblox',
    icon: '/apps/glowing-blox.png',
    description: isGerman ? 'Puzzle-Spiel' : 'Puzzle game',
    external: true,
  },
  {
    name: 'Alpine Welten',
    href: 'https://play.google.com/store/apps/details?id=com.alpinewelten.tourguide',
    icon: '/apps/alpine-welten-tourguide.jpg',
    description: 'Tourguide',
    external: true,
  },
  {
    name: 'Goory',
    href: 'https://apps.apple.com/de/app/goory/id6670455024',
    icon: '/apps/goory.jpg',
    description: isGerman ? 'Lokale Produkte' : 'Local products',
    external: true,
  },
  {
    name: 'GreenSP',
    href: 'https://play.google.com/store/apps/details?id=com.ranger.greensp',
    icon: '/apps/greensp.png',
    description: 'Ranger',
    external: true,
  },
  {
    name: 'ME SENSE',
    href: 'https://apps.apple.com/de/app/me-sense/id1616114697',
    icon: '/apps/me-sense.jpg',
    description: 'Weatherdock',
    external: true,
  },
  {
    name: 'Quasaro',
    href: 'https://apps.apple.com/de/app/quasaro/id1557640802',
    icon: '/apps/quasaro.jpg',
    description: isGerman ? 'Produktivität' : 'Productivity',
    external: true,
  },
  {
    name: 'Performance Suite',
    href: 'https://apps.apple.com/de/app/performance-suite/id1222858824',
    icon: '/apps/performance-suite.jpg',
    description: isGerman ? 'SEO-Tooling' : 'SEO tooling',
    external: true,
  },
  {
    name: 'mingleup',
    href: 'https://apps.apple.com/de/app/mingleup/id6670564412',
    icon: '/apps/mingleup.jpg',
    description: isGerman ? 'Social Events' : 'Social events',
    external: true,
  },
]
---

<section class="mt-16 animate-fade-in-up opacity-0 stagger-6">
  <div
    class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between mb-6"
  >
    <div>
      <p
        class="text-xs font-semibold uppercase tracking-wider text-warm-500 dark:text-warm-400"
      >
        {isGerman ? 'Ausgewählte Apps' : 'Selected apps'}
      </p>
      <h2
        class="text-2xl font-display font-bold text-warm-900 dark:text-warm-100"
      >
        {
          isGerman
            ? 'Apps, an denen ich gearbeitet habe'
            : 'Apps I’ve worked on'
        }
      </h2>
      <p class="text-warm-600 dark:text-warm-400 mt-1">
        {
          isGerman
            ? 'Mobile Produkte aus Kundenprojekten und Produktteams'
            : 'Mobile products from client work and product teams'
        }
      </p>
    </div>
    <a
      href={`${basePath}/work`}
      class="inline-flex items-center gap-2 text-sm font-medium text-accent-600 dark:text-accent-400 hover:text-accent-700 dark:hover:text-accent-300 transition-colors group"
    >
      {isGerman ? 'Mehr Projektarbeit' : 'More project work'}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="w-4 h-4 group-hover:translate-x-1 transition-transform"
      >
        <path
          fill-rule="evenodd"
          d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
          clip-rule="evenodd"></path>
      </svg>
    </a>
  </div>

  <div
    class="relative overflow-hidden rounded-2xl border border-warm-200 dark:border-warm-700/60 bg-white/70 dark:bg-dark-surface/80 p-5 sm:p-7"
  >
    <div
      class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-400/70 to-transparent"
    >
    </div>
    <div class="grid grid-cols-2 gap-x-5 gap-y-8 sm:grid-cols-4 lg:grid-cols-7">
      {
        apps.map((app) => (
          <a
            href={app.href}
            target={app.external ? '_blank' : undefined}
            rel={app.external ? 'noreferrer' : undefined}
            class="group flex flex-col items-center gap-3"
            aria-label={`${app.name} ${app.external ? (isGerman ? 'Link öffnen' : 'open link') : isGerman ? 'Projekt ansehen' : 'case study'}`}
          >
            <span class="relative block aspect-square h-20 w-20 overflow-hidden rounded-[22%] shadow-[0_10px_30px_rgba(0,0,0,0.16)] ring-1 ring-black/10 transition-all duration-300 before:pointer-events-none before:absolute before:inset-0 before:rounded-[inherit] before:bg-gradient-to-b before:from-white/25 before:to-transparent group-hover:-translate-y-1 group-hover:shadow-xl group-hover:shadow-accent-500/10 sm:h-24 sm:w-24 dark:ring-white/10">
              <img
                src={app.icon}
                alt={`${app.name} app icon`}
                width="96"
                height="96"
                loading="lazy"
                class="h-full w-full object-cover"
              />
            </span>
            <span class="text-center">
              <span class="block text-xs font-semibold leading-tight text-warm-900 dark:text-warm-100">
                {app.name}
              </span>
              <span class="mt-1 block text-[0.7rem] leading-tight text-warm-500 dark:text-warm-400">
                {app.description}
              </span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
