---
import '../styles/theme-toggle.css'

/**
 * ThemeToggle - animated light/dark switch
 * - Defaults to the active system preference
 * - Click stores the opposite explicit theme
 */
---

<button type="button" class="theme-toggle" aria-label="Toggle theme">
  <span class="theme-toggle__track" aria-hidden="true">
    <span class="theme-toggle__stars">
      <span class="theme-toggle__star theme-toggle__star--one"></span>
      <span class="theme-toggle__star theme-toggle__star--two"></span>
      <span class="theme-toggle__star theme-toggle__star--three"></span>
      <span class="theme-toggle__dot theme-toggle__dot--one"></span>
      <span class="theme-toggle__dot theme-toggle__dot--two"></span>
      <span class="theme-toggle__dot theme-toggle__dot--three"></span>
    </span>
    <span class="theme-toggle__cloud theme-toggle__cloud--one"></span>
    <span class="theme-toggle__cloud theme-toggle__cloud--two"></span>
    <span class="theme-toggle__thumb">
      <span class="theme-toggle__sun"></span>
      <span class="theme-toggle__moon"></span>
      <span class="theme-toggle__crater theme-toggle__crater--one"></span>
      <span class="theme-toggle__crater theme-toggle__crater--two"></span>
      <span class="theme-toggle__crater theme-toggle__crater--three"></span>
    </span>
  </span>
  <span class="sr-only" data-theme-label>Toggle theme</span>
</button>

<script>
  type ThemePreference = 'light' | 'dark' | null
  type ThemeState = 'light' | 'dark'

  let themeMediaListenerAttached = false
  let pendingThemeChange: number | null = null

  function getThemeToggles(): HTMLButtonElement[] {
    return Array.from(
      document.querySelectorAll<HTMLButtonElement>('.theme-toggle'),
    )
  }

  function getStoredTheme(): ThemePreference {
    const stored = localStorage.getItem('theme')
    return stored === 'light' || stored === 'dark' ? stored : null
  }

  function systemPrefersDark(): boolean {
    return window.matchMedia('(prefers-color-scheme: dark)').matches
  }

  function prefersReducedMotion(): boolean {
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches
  }

  function getEffectiveTheme(theme: ThemePreference): ThemeState {
    if (theme === 'light' || theme === 'dark') return theme
    return systemPrefersDark() ? 'dark' : 'light'
  }

  function applyTheme(theme: ThemePreference) {
    const effectiveTheme = getEffectiveTheme(theme)

    if (effectiveTheme === 'dark') {
      document.documentElement.classList.add('dark')
    } else {
      document.documentElement.classList.remove('dark')
    }
  }

  function updateState(toggle: HTMLButtonElement, theme: ThemePreference) {
    const effectiveTheme = getEffectiveTheme(theme)
    const isSystemTheme = theme === null
    const nextTheme = effectiveTheme === 'dark' ? 'light' : 'dark'
    const label = isSystemTheme
      ? `Theme: System ${effectiveTheme} mode. Click for ${nextTheme} mode.`
      : `Theme: ${effectiveTheme} mode. Click for ${nextTheme} mode.`
    const hiddenLabel = toggle.querySelector('[data-theme-label]')

    toggle.dataset.themeState = effectiveTheme
    toggle.dataset.themePreference = isSystemTheme ? 'system' : effectiveTheme
    toggle.setAttribute('aria-label', label)
    toggle.setAttribute(
      'aria-pressed',
      effectiveTheme === 'dark' ? 'true' : 'false',
    )

    if (hiddenLabel) {
      hiddenLabel.textContent = label
    }
  }

  function syncThemeToggles(themeOverride?: ThemePreference) {
    const theme = themeOverride ?? getStoredTheme()
    getThemeToggles().forEach((toggle) => updateState(toggle, theme))
  }

  function revealTheme(next: ThemeState) {
    const changeTheme = () => {
      applyTheme(next)
    }

    if (document.startViewTransition && !prefersReducedMotion()) {
      document.startViewTransition(changeTheme)
    } else {
      changeTheme()
    }
  }

  function startToggleTransition(next: ThemeState) {
    const duration = 900
    const direction = next === 'dark' ? 'to-dark' : 'to-light'

    getThemeToggles().forEach((toggle) => {
      updateState(toggle, next)
      toggle.dataset.themeDirection = direction
      toggle.dataset.themeAnimating = 'true'

      window.setTimeout(() => {
        delete toggle.dataset.themeAnimating
        delete toggle.dataset.themeDirection
      }, duration)
    })
  }

  function handleClick(event: MouseEvent) {
    if (pendingThemeChange !== null) return

    const current = getStoredTheme()
    const next = getEffectiveTheme(current) === 'dark' ? 'light' : 'dark'
    const x = event.clientX
    const y = event.clientY
    const delay = 700

    localStorage.setItem('theme', next)
    startToggleTransition(next)

    document.documentElement.style.setProperty('--view-transition-x', `${x}px`)
    document.documentElement.style.setProperty('--view-transition-y', `${y}px`)

    const commitThemeChange = () => {
      pendingThemeChange = null
      revealTheme(next)
    }

    pendingThemeChange = window.setTimeout(commitThemeChange, delay)
  }

  function initThemeToggle() {
    const toggles = getThemeToggles()
    if (!toggles.length) return

    const theme = getStoredTheme()
    applyTheme(theme)

    toggles.forEach((toggle) => {
      updateState(toggle, theme)

      if (toggle.dataset.themeReady === 'true') return

      toggle.dataset.themeReady = 'true'
      toggle.addEventListener('click', handleClick)
    })

    if (!themeMediaListenerAttached) {
      window
        .matchMedia('(prefers-color-scheme: dark)')
        .addEventListener('change', () => {
          if (getStoredTheme() !== null) return

          applyTheme(null)
          syncThemeToggles()
        })

      themeMediaListenerAttached = true
    }
  }

  initThemeToggle()

  document.addEventListener('astro:after-swap', initThemeToggle)
</script>
