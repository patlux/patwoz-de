---
type Language = 'en' | 'de'

type Logo = {
  alt: string
  src: string
  className: string
}

type Client = {
  name: string
  industry: Record<Language, string>
  note: Record<Language, string>
  href: Record<Language, string>
  external?: boolean
  logos: Logo[]
  accent: string
  tint: string
}

interface Props {
  lang?: Language
}

const { lang = 'en' } = Astro.props

const copy = {
  en: {
    title: 'Trusted by Industry Leaders',
