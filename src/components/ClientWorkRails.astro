    href: { en: '/work/kulturpass', de: '/de/work/kulturpass' },
    logos: [{ alt: 'SAP', src: '/company/sap.svg', className: 'logo-sap' }],
    accent: '#00a2e8',
    tint: 'rgba(0, 162, 232, 0.13)',
  },
  {
    name: 'Porsche Digital',
    industry: { en: 'Automotive', de: 'Automotive' },
    note: {
      en: 'Digital product teams in premium automotive contexts',
      de: 'Digitale Produktteams im Premium-Automotive-Umfeld',
    },
    href: { en: '/work/porsche', de: '/de/work/porsche' },
    logos: [
      {
        alt: 'Porsche',
        src: '/company/Porsche-Logo.webp',
        className: 'logo-porsche',
      },
    ],
    accent: '#d6b25e',
    tint: 'rgba(214, 178, 94, 0.13)',
  },
  {
    name: 'IBM iX',
    industry: { en: 'Technology', de: 'Technologie' },
    note: {
      en: 'Engineering for major brands and complex systems',
      de: 'Engineering für große Marken und komplexe Systeme',
    },
    href: { en: '/work/ibm', de: '/de/work/ibm' },
    logos: [
      { alt: 'IBM', src: '/company/IBM_logo.svg', className: 'logo-ibm' },
    ],
    accent: '#0f62fe',
    tint: 'rgba(15, 98, 254, 0.13)',
  },
  {
    name: 'Ströer / t-online',
    industry: { en: 'Media & Publishing', de: 'Medien & Publishing' },
    note: {
      en: 'High-reach media products and content platforms',
      de: 'Reichweitenstarke Medienprodukte und Content-Plattformen',
    },
    href: { en: '/work/stroeer', de: '/de/work/stroeer' },
    logos: [
      {
        alt: 'Ströer',
        src: '/company/str-logo-white.svg',
        className: 'logo-stroeer needs-dark-invert',
      },
      {
        alt: 't-online',
        src: '/company/t-online-desktop.327ab976.svg',
        className: 'logo-tonline needs-dark-invert',
      },
    ],
    accent: '#f5f5f5',
    tint: 'rgba(255, 255, 255, 0.09)',
  },
  {
    name: 'Olympia Verlag (Kicker)',
    industry: { en: 'Sports Media', de: 'Sportmedien' },
    note: {
      en: 'Live sports experiences for a loyal fanbase',
      de: 'Live-nahe Sporterlebnisse für eine loyale Fanbase',
    },
    href: { en: '/work/kicker', de: '/de/work/kicker' },
    logos: [
      { alt: 'Kicker', src: '/company/kicker.svg', className: 'logo-kicker' },
    ],
    accent: '#ed1c24',
    tint: 'rgba(237, 28, 36, 0.13)',
  },
  {
    name: 'ABL',
    industry: { en: 'E-Mobility', de: 'E-Mobility' },
    note: {
      en: 'Software for charging infrastructure and e-mobility workflows',
      de: 'Software für Ladeinfrastruktur und E-Mobility-Prozesse',
    },
    href: { en: '/work/abl', de: '/de/work/abl' },
    logos: [
      {
        alt: 'ABL',
        src: '/company/abl.svg',
        className: 'logo-abl needs-dark-invert',
      },
    ],
    accent: '#f5f5f5',
    tint: 'rgba(255, 255, 255, 0.09)',
  },
  {
    name: 'Barmer',
