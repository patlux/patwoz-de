  },
  {
    name: 'MHP',
    industry: { en: 'IT Consulting', de: 'IT-Beratung' },
    note: {
      en: 'Product engineering close to consulting for enterprise clients',
      de: 'Consulting-nahes Produktengineering für Enterprise-Kunden',
    },
    href: { en: 'https://www.mhp.com', de: 'https://www.mhp.com' },
    external: true,
    logos: [
      {
        alt: 'MHP',
        src: '/company/mhp.svg',
        className: 'logo-mhp needs-dark-invert',
      },
    ],
    accent: '#f5f243',
    tint: 'rgba(245, 242, 67, 0.13)',
