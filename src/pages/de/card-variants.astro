---
import '../../styles/global.css'

const skills = [
  { label: 'TypeScript', href: '/de/skills/typescript' },
  { label: 'React', href: '/de/skills/react' },
  { label: 'React Native', href: '/de/skills/react-native' },
  { label: 'Expo', href: '/de/skills/expo' },
  { label: 'Node.js', href: '/de/skills/nodejs' },
  { label: 'Rust / Go', href: '/de/skills/rust-go' },
  { label: 'AWS', href: '/de/skills/aws' },
  { label: 'DevOps', href: '/de/skills/devops' },
  { label: 'Docker', href: '/de/skills/docker' },
  { label: 'Kubernetes', href: '/de/skills/kubernetes' },
  { label: 'CI/CD', href: '/de/skills/ci-cd' },
  { label: 'Playwright', href: '/de/skills/playwright' },
]

const highlightLinks = [
  {
    label: 'Website',
    href: 'https://nuernberg-maps-review-removals.patwoz.dev/',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/patlux/nuernberg-maps-review-removals',
  },
]
---

<!doctype html>
<html lang="de" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Card Design Variants</title>
  </head>
  <body class="font-sans antialiased bg-black text-warm-100">
    <main class="min-h-screen px-6 py-10 sm:py-14">
      <div class="mx-auto w-full max-w-4xl">
        <header class="mb-10">
          <a
            href="/de"
            class="inline-flex items-center gap-2 text-sm font-medium text-warm-400 hover:text-white transition-colors"
          >
            ← Zur Startseite
          </a>
          <p
            class="mt-8 text-xs font-semibold uppercase tracking-[0.28em] text-accent-300"
          >
            Design-Auswahl
          </p>
          <h1 class="mt-2 text-4xl font-bold tracking-tight text-white">
            Karten-Varianten
          </h1>
          <p class="mt-3 max-w-2xl text-warm-400">
            Vier alternative Richtungen für die Expertise- und Highlight-Karten.
            Such dir einfach A, B, C oder D aus.
          </p>
        </header>

        <div class="space-y-14">
          <!-- Variant A -->
          <section aria-labelledby="variant-a" class="space-y-4">
            <div class="flex items-end justify-between gap-4">
              <div>
                <p
                  class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-300"
                >
                  Variante A
                </p>
                <h2 id="variant-a" class="mt-1 text-xl font-bold text-white">
                  Editorial Split
                </h2>
              </div>
              <span
                class="rounded-full border border-white/10 px-3 py-1 text-xs text-warm-400"
              >
                ruhig · premium · klar
              </span>
            </div>

            <div class="grid gap-5">
              <article
                class="group relative overflow-hidden rounded-[2rem] border border-white/12 bg-[#070707] p-6 shadow-2xl shadow-black/40"
              >
                <div
                  class="absolute inset-y-0 left-0 w-1.5 bg-gradient-to-b from-accent-300 via-white to-accent-700"
                >
                </div>
                <div
                  class="grid gap-7 lg:grid-cols-[0.9fr_1.5fr] lg:items-center"
                >
                  <div class="pl-2">
                    <p
                      class="text-xs font-bold uppercase tracking-[0.24em] text-warm-500"
                    >
                      Expertise
                    </p>
                    <h3
                      class="mt-3 text-3xl font-bold tracking-tight text-white"
                    >
                      Experte für moderne Produkt-Stacks
                    </h3>
                    <p class="mt-3 text-warm-400">
                      Kerntechnologien, mit denen ich täglich robuste Web- und
                      App-Produkte baue.
                    </p>
                  </div>
                  <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
                    {
                      skills.map((skill, index) => (
                        <a
                          href={skill.href}
                          class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/[0.04] px-3 py-2.5 text-sm font-semibold text-white transition-all hover:-translate-y-0.5 hover:border-accent-300/70 hover:bg-white/[0.08]"
                        >
                          <span>{skill.label}</span>
                          <span class="text-[10px] font-bold text-warm-600">
                            {(index + 1).toString().padStart(2, '0')}
                          </span>
                        </a>
                      ))
                    }
                  </div>
                </div>
              </article>

              <article
                class="relative overflow-hidden rounded-[2rem] border border-accent-400/30 bg-[#070707] p-6 shadow-2xl shadow-accent-950/30"
              >
                <div
                  class="absolute right-0 top-0 h-32 w-32 rounded-bl-full bg-accent-500/20 blur-2xl"
                >
                </div>
                <div
                  class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between"
                >
                  <div>
                    <p
                      class="text-xs font-bold uppercase tracking-[0.24em] text-accent-300"
                    >
                      Highlight: Eigenes Projekt
                    </p>
                    <h3
                      class="mt-3 text-3xl font-bold tracking-tight text-white"
                    >
                      Nürnberg Maps Review Removals
                    </h3>
                    <p
                      class="mt-3 max-w-2xl text-lg leading-relaxed text-warm-400"
                    >
                      Lokales Datenprojekt zur Analyse von Löschhinweisen bei
                      Google-Maps-Bewertungen in Nürnberg.
                    </p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {
                      highlightLinks.map((link) => (
                        <a
                          href={link.href}
                          target="_blank"
                          rel="noreferrer"
                          class="rounded-full border border-white/15 bg-white px-4 py-2 text-sm font-bold text-black transition-all hover:-translate-y-0.5 hover:bg-accent-100"
                        >
                          {link.label}
                        </a>
                      ))
                    }
                  </div>
                </div>
              </article>
            </div>
          </section>

          <!-- Variant B -->
          <section aria-labelledby="variant-b" class="space-y-4">
            <div class="flex items-end justify-between gap-4">
              <div>
                <p
                  class="text-xs font-semibold uppercase tracking-[0.22em] text-emerald-300"
                >
                  Variante B
                </p>
                <h2 id="variant-b" class="mt-1 text-xl font-bold text-white">
                  Command Center
                </h2>
              </div>
              <span
                class="rounded-full border border-emerald-300/20 px-3 py-1 text-xs text-warm-400"
              >
                technisch · direkt · präzise
              </span>
            </div>

            <div class="grid gap-5">
              <article
                class="relative overflow-hidden rounded-xl border border-emerald-300/25 bg-[#050806] p-6 shadow-2xl shadow-emerald-950/20"
              >
                <div
                  class="absolute inset-0 opacity-20"
                  style="background-image: linear-gradient(rgba(52, 211, 153, 0.16) 1px, transparent 1px), linear-gradient(90deg, rgba(52, 211, 153, 0.16) 1px, transparent 1px); background-size: 28px 28px;"
                >
                </div>
                <div
                  class="relative grid gap-7 lg:grid-cols-[0.82fr_1.6fr] lg:items-center"
                >
                  <div class="font-mono">
                    <p
                      class="text-xs uppercase tracking-[0.2em] text-emerald-300"
                    >
                      ./expertise
                    </p>
                    <h3
                      class="mt-3 text-3xl font-bold tracking-tight text-white"
                    >
                      Stack bereit
                    </h3>
                    <p class="mt-3 text-sm leading-relaxed text-warm-400">
                      Jeden Tag im Einsatz. Öffne eine Kompetenz und springe zu
                      echten Projekten.
                    </p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {
                      skills.map((skill) => (
                        <a
                          href={skill.href}
                          class="font-mono rounded-lg border border-emerald-300/20 bg-black/35 px-3 py-2 text-sm font-semibold text-emerald-50 transition-all hover:-translate-y-0.5 hover:border-emerald-300 hover:bg-emerald-300 hover:text-black"
                        >
                          {skill.label} ↗
                        </a>
                      ))
                    }
                  </div>
                </div>
              </article>

              <article
                class="relative overflow-hidden rounded-xl border border-emerald-300/25 bg-[#050806] p-6"
              >
                <div
                  class="absolute left-6 top-0 h-px w-48 bg-gradient-to-r from-emerald-300 to-transparent"
                >
                </div>
                <div
                  class="relative flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between"
                >
                  <div class="font-mono">
                    <p
                      class="text-xs uppercase tracking-[0.2em] text-emerald-300"
                    >
                      local-data-project
                    </p>
                    <h3
                      class="mt-3 text-3xl font-bold tracking-tight text-white"
                    >
                      Nürnberg Maps Review Removals
                    </h3>
                    <p
                      class="mt-3 max-w-2xl text-sm leading-relaxed text-warm-400"
                    >
                      Analyse von Löschhinweisen bei Google-Maps-Bewertungen in
                      Nürnberg.
                    </p>
                  </div>
                  <div class="flex flex-wrap gap-2 font-mono">
                    {
                      highlightLinks.map((link) => (
                        <a
                          href={link.href}
                          target="_blank"
                          rel="noreferrer"
                          class="rounded-lg border border-emerald-300/25 bg-emerald-300 px-4 py-2 text-sm font-bold text-black transition-all hover:-translate-y-0.5 hover:bg-emerald-200"
                        >
                          {link.label} →
                        </a>
                      ))
                    }
                  </div>
                </div>
              </article>
            </div>
          </section>

          <!-- Variant C -->
          <section aria-labelledby="variant-c" class="space-y-4">
            <div class="flex items-end justify-between gap-4">
              <div>
                <p
                  class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-300"
                >
                  Variante C
                </p>
                <h2 id="variant-c" class="mt-1 text-xl font-bold text-white">
                  Soft Bento
                </h2>
              </div>
              <span
                class="rounded-full border border-sky-300/20 px-3 py-1 text-xs text-warm-400"
              >
                freundlich · modern · lebendig
              </span>
            </div>

            <div class="grid gap-5">
              <article
                class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.03] p-3 shadow-2xl shadow-black/30"
              >
                <div
                  class="absolute -right-16 -top-20 h-56 w-56 rounded-full bg-sky-400/20 blur-3xl"
                >
                </div>
                <div class="relative grid gap-3 lg:grid-cols-[0.95fr_1.55fr]">
                  <div
                    class="rounded-[1.55rem] border border-white/10 bg-black/45 p-5"
                  >
                    <p
                      class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-300"
                    >
                      Expertise
                    </p>
                    <h3
                      class="mt-3 text-3xl font-bold tracking-tight text-white"
                    >
                      Fokus auf Apps, Plattformen und Delivery
                    </h3>
                    <p class="mt-3 text-warm-400">
                      Ein kompakter Überblick über Technologien, die sich in
                      echten Projekten bewährt haben.
                    </p>
                  </div>
                  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
                    {
                      skills.map((skill) => (
                        <a
                          href={skill.href}
                          class="min-h-20 rounded-[1.25rem] border border-white/10 bg-black/35 p-3 text-sm font-bold text-white transition-all hover:-translate-y-1 hover:border-sky-300/60 hover:bg-sky-300/10"
                        >
                          <span class="mb-3 block h-2 w-2 rounded-full bg-sky-300" />
                          {skill.label}
                        </a>
                      ))
                    }
                  </div>
                </div>
              </article>

              <article
                class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.03] p-3"
              >
                <div
                  class="relative rounded-[1.55rem] border border-white/10 bg-black/45 p-5"
                >
                  <div class="grid gap-6 sm:grid-cols-[1fr_auto] sm:items-end">
                    <div>
                      <div
                        class="mb-4 inline-flex rounded-full bg-sky-300/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-sky-200"
                      >
                        Eigenes Projekt
                      </div>
                      <h3 class="text-3xl font-bold tracking-tight text-white">
                        Nürnberg Maps Review Removals
                      </h3>
                      <p class="mt-3 max-w-2xl text-warm-400">
                        Lokales Datenprojekt zur Analyse von Löschhinweisen bei
                        Google-Maps-Bewertungen in Nürnberg.
                      </p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                      {
                        highlightLinks.map((link) => (
                          <a
                            href={link.href}
                            target="_blank"
                            rel="noreferrer"
                            class="rounded-2xl border border-white/10 bg-white px-4 py-2 text-sm font-bold text-black transition-all hover:-translate-y-0.5 hover:bg-sky-100"
                          >
                            {link.label}
                          </a>
                        ))
                      }
                    </div>
                  </div>
                </div>
              </article>
            </div>
          </section>

          <!-- Variant D -->
          <section aria-labelledby="variant-d" class="space-y-4">
            <div class="flex items-end justify-between gap-4">
              <div>
                <p
                  class="text-xs font-semibold uppercase tracking-[0.22em] text-white"
                >
                  Variante D
                </p>
                <h2 id="variant-d" class="mt-1 text-xl font-bold text-white">
                  Brutalist Label
                </h2>
              </div>
              <span
                class="rounded-full border border-white/20 px-3 py-1 text-xs text-warm-400"
              >
                kantig · kontrastreich · eigenständig
              </span>
            </div>

            <div class="grid gap-5">
              <article
                class="border-2 border-white bg-black p-5 shadow-[8px_8px_0_0_#fff]"
              >
                <div
                  class="grid gap-7 lg:grid-cols-[0.8fr_1.55fr] lg:items-start"
                >
                  <div>
                    <div
                      class="inline-flex border border-white px-2 py-1 text-xs font-black uppercase tracking-[0.2em] text-white"
                    >
                      01 / Expertise
                    </div>
                    <h3
                      class="mt-5 text-4xl font-black uppercase leading-none tracking-tight text-white"
                    >
                      Experte für
                    </h3>
                    <p class="mt-4 max-w-sm text-warm-300">
                      Kerntechnologien, mit denen ich täglich arbeite.
                    </p>
                  </div>
                  <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
                    {
                      skills.map((skill) => (
                        <a
                          href={skill.href}
                          class="border border-white bg-black px-3 py-3 text-sm font-black uppercase tracking-tight text-white transition-colors hover:bg-white hover:text-black"
                        >
                          {skill.label} →
                        </a>
                      ))
                    }
                  </div>
                </div>
              </article>

              <article
                class="border-2 border-white bg-white p-5 text-black shadow-[8px_8px_0_0_#6366f1]"
              >
                <div class="grid gap-6 sm:grid-cols-[1fr_auto] sm:items-center">
                  <div>
                    <p
                      class="text-xs font-black uppercase tracking-[0.24em] text-black/60"
                    >
                      02 / Eigenes Projekt
                    </p>
                    <h3
                      class="mt-3 text-4xl font-black uppercase leading-none tracking-tight !text-black"
                    >
                      Nürnberg Maps Review Removals
                    </h3>
                    <p class="mt-4 max-w-2xl text-lg font-medium text-black/70">
                      Lokales Datenprojekt zur Analyse von Löschhinweisen bei
                      Google-Maps-Bewertungen in Nürnberg.
                    </p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {
                      highlightLinks.map((link) => (
                        <a
                          href={link.href}
                          target="_blank"
                          rel="noreferrer"
                          class="border-2 border-black bg-black px-4 py-2 text-sm font-black uppercase text-white transition-colors hover:bg-white hover:text-black"
                        >
                          {link.label}
                        </a>
                      ))
                    }
                  </div>
                </div>
              </article>
            </div>
          </section>
        </div>
      </div>
    </main>
  </body>
</html>
