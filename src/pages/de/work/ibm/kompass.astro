---
import Layout from '~/layouts/Layout.astro'
import BaseLayout from '~/components/BaseLayout.astro'
import Footer from '~/components/Footer.astro'
import AppStoreLinks from '~/components/AppStoreLinks.astro'

const pageTitle = 'Barmer App - Kompass Modul'
const description =
  'Kompass-Modul Arbeit für die Barmer App über Mobile und Web, mit Fokus auf Leistungsflows, Rebranding, Accessibility und Plattformstabilität.'
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Startseite',
      item: new URL('/de', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Referenzen',
      item: new URL('/de/work', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: pageTitle,
      item: canonicalURL.toString(),
    },
  ],
}
---

<Layout
  title="Barmer App - Kompass Modul - Referenzen"
  description={description}
  lang="de"
>
  <BaseLayout>
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
    <article class="mt-12">
      <a
        href="/de/work/ibm"
        class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 mb-6"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-4 h-4"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15.75 19.5 8.25 12l7.5-7.5"></path>
        </svg>
        Zurück zu IBM / Barmer
      </a>

      <header class="mb-12">
        <div class="flex flex-col sm:flex-row gap-6 items-start">
          <div
            class="flex-shrink-0 flex items-center justify-center w-24 h-24 bg-gray-50 dark:bg-zinc-800 rounded-xl border border-gray-200 dark:border-zinc-700"
          >
            <img
              src="/company/barmer.svg"
              alt="Barmer Logo"
              width="70"
              height="20"
            />
          </div>
          <div class="flex-1">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
              Barmer App - Kompass Modul
            </h1>
            <p class="text-gray-600 dark:text-gray-400 mt-1">IBM iX / Barmer</p>
            <div
              class="flex flex-wrap gap-4 mt-3 text-sm text-gray-500 dark:text-gray-400"
            >
              <span class="flex items-center gap-1">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-4 h-4"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"
                  ></path>
                </svg>
                Senior Frontend Developer
              </span>
            </div>
          </div>
        </div>

        <AppStoreLinks
          appStoreUrl="https://apps.apple.com/de/app/barmer-app/id956752981"
          playStoreUrl="https://play.google.com/store/apps/details?id=de.barmergek.serviceapp&hl=de"
        />
      </header>

      <div class="prose lg:prose-lg max-w-none">
        <p>
          Das Kompass Modul ist Teil der Barmer App und der Meine Barmer Web
          Experience. Es unterstützt Versicherte bei Leistungs- und
          Erstattungsthemen wie Pflegeleistungen, Krankengeld, Reha,
          Hilfsmittel, Mutterschaftsgeld, Kieferorthopädie und laufenden
          Vorgängen.
        </p>

        <h2>Projektüberblick</h2>
        <p>
          Als Senior Frontend Developer im Kompass Team habe ich zwischen
          Dezember 2025 und April 2026 über 310 Commits im Frontend-Monorepo
          geliefert. Der Schwerpunkt lag auf dem gemeinsamen Kompass Feature
          Package, das sowohl in der React Native App als auch in der React
          Native Web Oberfläche genutzt wird, mit konsistentem Verhalten auf
          iOS, Android und Web.
        </p>

        <h2>Wichtige Beiträge</h2>

        <h3>Rebranding & Feature Screens</h3>
        <p>
          Rebranded Screens und Komponenten im gesamten Modul umgesetzt,
          inklusive Überblick-Tabs, Info-Bereichen, Fehlerscreens und
          Detailseiten. Die Arbeit betraf Pflege, Mutterschaftsgeld, Reha,
          Hilfsmittel, Krankengeld, Kinderkrankengeld und KFO-Flows, jeweils
          ausgerichtet am Barmer Puls Design System.
        </p>

        <h3>Leistungs- & Erstattungsflows</h3>
        <p>
          UI-Flows für Leistungsüberblicke, Auszahlungslisten, regelmäßige
          Pflegeleistungen, Kostenübersichten, Status-Chips und Detailseiten
          gebaut und geschärft. Dazu gehörten stabilere Empty States, visuell
          robuste Finanzzeilen und gut lesbare Listen-Zusammenfassungen auf
          kompakten Mobile Layouts.
        </p>

        <h3>Accessibility</h3>
        <p>
          VoiceOver- und TalkBack-Verhalten für Header, Tabs, Filter, Selects,
          Links und Vorgangsdetailseiten verbessert. Android Screenreader
          Workarounds ergänzt, Reading Order korrigiert, doppelte Ansagen
          vermieden und korrekte Link-Semantik im Web sichergestellt.
        </p>

        <h3>Keyboard, Layout & Navigation Stability</h3>
        <p>
          Keyboard-aware Verhalten für Formulare und Dialoge integriert,
          inklusive Feedback Dialog, Reha-Zuzahlung und fixierten Action Bars.
          Außerdem Bottom-Navigation Abstände, Landscape Dialoge, Tab-Panel
          Height Crashes sowie native DatePicker- und SectionList-Crashes
          behoben.
        </p>

        <h3>Info- & Tipps Experience</h3>
        <p>
          Info-Tabs, Accordions, Tipp-Karten und PDF-bezogene Loading States
          überarbeitet. Dazu gehörten CardSwipeView Integration,
          Dokumentgrößen-Formatierung, Soft-Hyphen Handling für lange deutsche
          Begriffe und bessere Zeilenumbrüche auf iOS und Android.
        </p>

        <h3>Testing & Regression Coverage</h3>
        <p>
          Eine große Snapshot-Suite während der Änderungen aktuell gehalten,
          gezielte Tests für neues Layout-Verhalten ergänzt und Lint- sowie
          Type-Issues im Rebranding behoben. Das machte wiederholte
          Main-/Candidate-Backports für Release-Vorbereitungen sicherer.
        </p>
      </div>

      <div class="prose lg:prose-lg max-w-none mt-8">
        <h2>Technologie-Stack</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-6 mb-12">
        <div>
          <h4
            class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase mb-3"
          >
            Mobile
          </h4>
          <ul class="space-y-2">
            <li class="text-gray-700 dark:text-gray-300">React Native</li>
            <li class="text-gray-700 dark:text-gray-300">TypeScript</li>
            <li class="text-gray-700 dark:text-gray-300">React Navigation</li>
            <li class="text-gray-700 dark:text-gray-300">Barmer Puls UI</li>
          </ul>
        </div>
        <div>
          <h4
            class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase mb-3"
          >
            Web
          </h4>
          <ul class="space-y-2">
            <li class="text-gray-700 dark:text-gray-300">React</li>
            <li class="text-gray-700 dark:text-gray-300">React Native Web</li>
            <li class="text-gray-700 dark:text-gray-300">React Router</li>
            <li class="text-gray-700 dark:text-gray-300">Webpack</li>
          </ul>
        </div>
        <div>
          <h4
            class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase mb-3"
          >
            Architecture
          </h4>
          <ul class="space-y-2">
            <li class="text-gray-700 dark:text-gray-300">Yarn Workspaces</li>
            <li class="text-gray-700 dark:text-gray-300">Lerna Monorepo</li>
            <li class="text-gray-700 dark:text-gray-300">Redux Toolkit</li>
            <li class="text-gray-700 dark:text-gray-300">i18next</li>
          </ul>
        </div>
        <div>
          <h4
            class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase mb-3"
          >
            Quality
          </h4>
          <ul class="space-y-2">
            <li class="text-gray-700 dark:text-gray-300">Jest</li>
            <li class="text-gray-700 dark:text-gray-300">
              React Native Testing Library
            </li>
            <li class="text-gray-700 dark:text-gray-300">Snapshot Testing</li>
            <li class="text-gray-700 dark:text-gray-300">ESLint</li>
          </ul>
        </div>
      </div>
    </article>

    <Footer />
  </BaseLayout>
</Layout>
