---
import Layout from '~/layouts/Layout.astro'
import BaseLayout from '~/components/BaseLayout.astro'
import Footer from '~/components/Footer.astro'
import Introduction from '~/components/Introduction.astro'
import AppIconShowcase from '~/components/AppIconShowcase.astro'

const skillRows = [
  [
    { label: 'TypeScript', href: '/de/skills/typescript' },
    { label: 'React', href: '/de/skills/react' },
    { label: 'React Native', href: '/de/skills/react-native' },
  ],
  [
    { label: 'Expo', href: '/de/skills/expo' },
    { label: 'Node.js', href: '/de/skills/nodejs' },
    { label: 'Rust / Go', href: '/de/skills/rust-go' },
  ],
  [
    { label: 'AWS', href: '/de/skills/aws' },
    { label: 'DevOps', href: '/de/skills/devops' },
    { label: 'Docker', href: '/de/skills/docker' },
  ],
  [
    { label: 'Kubernetes', href: '/de/skills/kubernetes' },
    { label: 'CI/CD', href: '/de/skills/ci-cd' },
    { label: 'Playwright', href: '/de/skills/e2e-testing' },
  ],
]
---

<Layout
  title="Patrick Wozniak: Software Engineer"
  description="Patrick Wozniak ist ein autodidaktischer Software Engineer aus Nürnberg, Deutschland."
  lang="de"
>
  <BaseLayout>
    <Introduction />

    <!-- Expertise Section -->
    <section class="mt-16 animate-fade-in-up opacity-0 stagger-4">
      <div
        class="overflow-hidden rounded-2xl border border-warm-200 bg-white shadow-sm dark:border-warm-800 dark:bg-dark-surface dark:shadow-2xl dark:shadow-black/30"
      >
        <div
          class="flex items-center justify-between border-b border-warm-200 px-5 py-3 dark:border-warm-800"
        >
          <p
            class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600 dark:text-accent-300"
          >
            Expertise
          </p>
          <p class="text-xs text-warm-500 dark:text-warm-600">12 Kompetenzen</p>
        </div>
        <div class="grid gap-0 lg:grid-cols-[0.78fr_1.65fr]">
          <div
            class="border-b border-warm-200 p-5 dark:border-warm-800 lg:border-b-0 lg:border-r"
          >
            <h2
              class="text-3xl font-display font-bold tracking-tight text-warm-900 dark:text-white"
            >
              Tech Ledger
            </h2>
            <p class="mt-3 text-warm-600 dark:text-warm-400">
              Ein sachlicher Index meiner Kerntechnologien.
            </p>
          </div>
          <div class="divide-y divide-warm-200 dark:divide-warm-800">
            {
              skillRows.map((row) => (
                <div class="grid grid-cols-1 divide-y divide-warm-200 dark:divide-warm-800 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
                  {row.map((skill) => (
                    <a
                      href={skill.href}
                      class="ledger-hover-cell flex items-center justify-between px-4 py-3 text-sm font-semibold text-warm-900 dark:text-warm-100"
                    >
                      {skill.label}
                      <span class="ledger-hover-arrow">→</span>
                    </a>
                  ))}
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Client Work Section -->
    <section class="mt-16 animate-fade-in-up opacity-0 stagger-5">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2
            class="text-2xl font-display font-bold text-warm-900 dark:text-warm-100"
          >
            Vertrauen von Branchenführern
          </h2>
          <p class="text-warm-600 dark:text-warm-400 mt-1">
            Unternehmen, mit denen ich starke Produkte gebaut habe
          </p>
        </div>
        <a
          href="/de/work"
          class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-accent-600 dark:text-accent-400 hover:text-accent-700 dark:hover:text-accent-300 transition-colors group"
        >
          Alle Projekte ansehen
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4 group-hover:translate-x-1 transition-transform"
          >
            <path
              fill-rule="evenodd"
              d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <a
          href="/de/work/kulturpass"
          class="card-soft p-5 flex items-center gap-4 group hover-lift"
        >
          <div
            class="w-14 h-14 flex items-center justify-center bg-warm-100 dark:bg-dark-elevated rounded-xl group-hover:bg-warm-200 dark:group-hover:bg-warm-800/30 transition-colors"
          >
            <img alt="SAP" src="/company/sap.svg" class="h-7 w-auto" />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-warm-900 dark:text-warm-100 block"
              >SAP / KulturPass</span
            >
            <span class="text-sm text-warm-500 dark:text-warm-400"
              >Enterprise Software</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="w-5 h-5"
            >
              <path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
        </a>

        <a
          href="/de/work/porsche"
          class="card-soft p-5 flex items-center gap-4 group hover-lift"
        >
          <div
            class="w-14 h-14 flex items-center justify-center bg-warm-100 dark:bg-dark-elevated rounded-xl group-hover:bg-warm-200 dark:group-hover:bg-warm-800/30 transition-colors"
          >
            <img
              alt="Porsche"
              src="/company/Porsche-Logo.webp"
              class="h-9 w-auto"
            />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-warm-900 dark:text-warm-100 block"
              >Porsche Digital</span
            >
            <span class="text-sm text-warm-500 dark:text-warm-400"
              >Automotive</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
