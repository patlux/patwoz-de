            <span class="text-sm text-warm-500 dark:text-warm-400"
              >IT-Beratung</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-5 h-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
              ></path>
            </svg>
          </div>
        </a>

        <a
          href="https://finanzguru.de"
          target="_blank"
          rel="noreferrer"
          class="card-soft p-5 flex items-center gap-4 group hover-lift"
        >
          <div
            class="w-14 h-14 flex items-center justify-center bg-warm-100 dark:bg-dark-elevated rounded-xl group-hover:bg-warm-200 dark:group-hover:bg-warm-800/30 transition-colors"
          >
            <img
              alt="Finanzguru"
              src="/company/finanzguru.svg"
              class="h-8 w-auto"
            />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-warm-900 dark:text-warm-100 block"
              >Finanzguru</span
            >
            <span class="text-sm text-warm-500 dark:text-warm-400">FinTech</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-5 h-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
              ></path>
            </svg>
          </div>
        </a>
      </div>

      <a
        href="/de/work"
        class="sm:hidden mt-4 w-full inline-flex items-center justify-center gap-2 text-sm font-medium text-accent-600 dark:text-accent-400 hover:text-accent-700 dark:hover:text-accent-300 transition-colors py-3 border border-warm-200 dark:border-warm-700 rounded-xl"
      >
        Alle Projekte ansehen
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="w-4 h-4"
        >
          <path
            fill-rule="evenodd"
            d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
    </section>

    <AppIconShowcase lang="de" />

    <section class="mt-16 animate-fade-in-up opacity-0 stagger-6">
      <article
        class="overflow-hidden rounded-2xl border border-warm-200 bg-white shadow-sm dark:border-warm-800 dark:bg-dark-surface dark:shadow-2xl dark:shadow-black/30"
      >
        <div class="grid gap-0 lg:grid-cols-[1fr_18rem]">
          <div class="p-5 sm:p-6">
            <p
              class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600 dark:text-accent-300"
            >
              Highlight: eigenes Projekt
            </p>
            <h2
              class="mt-3 text-2xl font-display font-bold tracking-tight text-warm-900 dark:text-white"
            >
              Nürnberg Maps Review Removals
            </h2>
            <p class="mt-3 max-w-2xl text-warm-600 dark:text-warm-400">
              Lokales Datenprojekt zur Analyse von Löschhinweisen bei
              Google-Maps-Bewertungen in Nürnberg.
            </p>
          </div>
          <div
            class="grid grid-cols-2 border-t border-warm-200 dark:border-warm-800 lg:border-l lg:border-t-0"
          >
            <a
              href="https://nuernberg-maps-review-removals.patwoz.dev/"
              target="_blank"
              rel="noreferrer"
              class="ledger-hover-cell flex min-h-28 flex-col justify-between border-r border-warm-200 p-4 dark:border-warm-800"
            >
              <span
                class="ledger-hover-kicker text-[10px] font-semibold uppercase tracking-[0.2em] text-warm-500 dark:text-warm-600"
              >
                Öffnen
              </span>
              <span
                class="flex items-center justify-between text-sm font-bold text-warm-900 dark:text-white"
              >
                Website
                <span class="ledger-hover-arrow">→</span>
              </span>
            </a>
            <a
              href="https://github.com/patlux/nuernberg-maps-review-removals"
              target="_blank"
              rel="noreferrer"
              class="ledger-hover-cell flex min-h-28 flex-col justify-between p-4"
            >
              <span
                class="ledger-hover-kicker text-[10px] font-semibold uppercase tracking-[0.2em] text-warm-500 dark:text-warm-600"
              >
                Öffnen
              </span>
              <span
                class="flex items-center justify-between text-sm font-bold text-warm-900 dark:text-white"
              >
                GitHub
                <span class="ledger-hover-arrow">→</span>
              </span>
            </a>
          </div>
        </div>
      </article>
    </section>

    <section
      class="mt-16 animate-fade-in-up opacity-0 stagger-7 p-6 card-soft bg-gradient-to-br from-warm-50 to-warm-100 dark:from-dark-surface dark:to-dark-elevated"
    >
      <div class="flex items-start gap-4">
        <div
          class="w-12 h-12 flex items-center justify-center bg-warm-200 dark:bg-warm-800/30 rounded-xl flex-shrink-0"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="w-6 h-6 text-accent-600 dark:text-accent-400"
