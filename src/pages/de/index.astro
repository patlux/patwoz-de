            >
            <span class="text-sm text-warm-500 dark:text-warm-400"
              >Technologie</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="w-5 h-5"
            >
              <path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
        </a>

        <a
          href="/de/work/stroeer"
          class="card-soft p-5 flex items-center gap-4 group hover-lift"
        >
          <div
            class="w-14 h-14 flex flex-col items-center justify-center bg-warm-100 dark:bg-dark-elevated rounded-xl group-hover:bg-warm-200 dark:group-hover:bg-warm-800/30 transition-colors gap-0.5"
          >
            <img
              alt="Ströer"
              src="/company/str-logo-white.svg"
              class="h-3 w-auto dark:invert"
            />
            <img
              alt="t-online"
              src="/company/t-online-desktop.327ab976.svg"
              class="h-2.5 w-auto dark:invert"
            />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-warm-900 dark:text-warm-100 block"
              >Ströer / t-online</span
            >
            <span class="text-sm text-warm-500 dark:text-warm-400"
              >Medien & Publishing</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="w-5 h-5"
            >
              <path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
        </a>

        <a
          href="/de/work/kicker"
          class="card-soft p-5 flex items-center gap-4 group hover-lift"
        >
          <div
            class="w-14 h-14 flex items-center justify-center bg-warm-100 dark:bg-dark-elevated rounded-xl group-hover:bg-warm-200 dark:group-hover:bg-warm-800/30 transition-colors"
          >
            <img alt="Kicker" src="/company/kicker.svg" class="h-6 w-auto" />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-warm-900 dark:text-warm-100 block"
              >Olympia Verlag (Kicker)</span
            >
            <span class="text-sm text-warm-500 dark:text-warm-400"
              >Sportmedien</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="w-5 h-5"
            >
              <path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
        </a>

        <a
          href="/de/work/abl"
          class="card-soft p-5 flex items-center gap-4 group hover-lift"
        >
          <div
            class="w-14 h-14 flex items-center justify-center bg-warm-100 dark:bg-dark-elevated rounded-xl group-hover:bg-warm-200 dark:group-hover:bg-warm-800/30 transition-colors"
          >
            <img
              alt="ABL"
              src="/company/abl.svg"
              class="h-6 w-auto dark:invert"
            />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-warm-900 dark:text-warm-100 block"
              >ABL</span
            >
            <span class="text-sm text-warm-500 dark:text-warm-400"
              >E-Mobility</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="w-5 h-5"
            >
              <path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
        </a>

        <a
          href="/de/work/ibm"
          class="card-soft p-5 flex items-center gap-4 group hover-lift"
        >
          <div
            class="w-14 h-14 flex items-center justify-center bg-warm-100 dark:bg-dark-elevated rounded-xl group-hover:bg-warm-200 dark:group-hover:bg-warm-800/30 transition-colors"
          >
            <img alt="Barmer" src="/company/barmer.svg" class="h-6 w-auto" />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-warm-900 dark:text-warm-100 block"
              >Barmer</span
            >
            <span class="text-sm text-warm-500 dark:text-warm-400"
              >Krankenversicherung</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="w-5 h-5"
            >
              <path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd"></path>
            </svg>
          </div>
        </a>

        <a
          href="https://www.enerparc.de"
          target="_blank"
          rel="noreferrer"
          class="card-soft p-5 flex items-center gap-4 group hover-lift"
        >
          <div
            class="w-14 h-14 flex items-center justify-center bg-warm-100 dark:bg-dark-elevated rounded-xl group-hover:bg-warm-200 dark:group-hover:bg-warm-800/30 transition-colors"
          >
            <img
              alt="Enerparc"
              src="/company/enerparc.svg"
              class="h-6 w-auto"
            />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-warm-900 dark:text-warm-100 block"
              >Enerparc</span
            >
            <span class="text-sm text-warm-500 dark:text-warm-400"
              >Erneuerbare Energien</span
            >
          </div>
          <div
            class="text-warm-400 group-hover:text-accent-500 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-5 h-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
              ></path>
            </svg>
          </div>
        </a>

        <a
          href="https://www.mhp.com"
          target="_blank"
          rel="noreferrer"
          class="card-soft p-5 flex items-center gap-4 group hover-lift"
        >
          <div
            class="w-14 h-14 flex items-center justify-center bg-warm-100 dark:bg-dark-elevated rounded-xl group-hover:bg-warm-200 dark:group-hover:bg-warm-800/30 transition-colors"
          >
            <img
              alt="MHP"
              src="/company/mhp.svg"
              class="h-7 w-auto dark:invert"
            />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-warm-900 dark:text-warm-100 block"
              >MHP</span
