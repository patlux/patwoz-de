---
import Layout from '~/layouts/Layout.astro'
import BaseLayout from '~/components/BaseLayout.astro'
import Footer from '~/components/Footer.astro'
import Introduction from '~/components/Introduction.astro'
import AppIconShowcase from '~/components/AppIconShowcase.astro'
import ClientWorkRails from '~/components/ClientWorkRails.astro'

const skillRows = [
  [
    { label: 'TypeScript', href: '/de/skills/typescript' },
    { label: 'React', href: '/de/skills/react' },
    { label: 'React Native', href: '/de/skills/react-native' },
  ],
  [
    { label: 'Expo', href: '/de/skills/expo' },
    { label: 'Node.js', href: '/de/skills/nodejs' },
    { label: 'Rust / Go', href: '/de/skills/rust-go' },
  ],
  [
    { label: 'AWS', href: '/de/skills/aws' },
    { label: 'DevOps', href: '/de/skills/devops' },
    { label: 'Docker', href: '/de/skills/docker' },
  ],
  [
    { label: 'Kubernetes', href: '/de/skills/kubernetes' },
    { label: 'CI/CD', href: '/de/skills/ci-cd' },
    { label: 'Playwright', href: '/de/skills/e2e-testing' },
  ],
]
---

<Layout
  title="Patrick Wozniak: Software Engineer"
  description="Patrick Wozniak ist ein autodidaktischer Software Engineer aus Nürnberg, Deutschland."
  lang="de"
>
  <BaseLayout>
    <Introduction />

    <!-- Expertise Section -->
    <section class="mt-16 animate-fade-in-up opacity-0 stagger-4">
      <div
        class="overflow-hidden rounded-2xl border border-warm-200 bg-white shadow-sm dark:border-warm-800 dark:bg-dark-surface dark:shadow-2xl dark:shadow-black/30"
      >
        <div
          class="flex items-center justify-between border-b border-warm-200 px-5 py-3 dark:border-warm-800"
        >
          <p
            class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600 dark:text-accent-300"
          >
            Expertise
          </p>
          <p class="text-xs text-warm-500 dark:text-warm-600">12 Kompetenzen</p>
        </div>
        <div class="grid gap-0 lg:grid-cols-[0.78fr_1.65fr]">
          <div
            class="border-b border-warm-200 p-5 dark:border-warm-800 lg:border-b-0 lg:border-r"
          >
            <h2
              class="text-3xl font-display font-bold tracking-tight text-warm-900 dark:text-white"
            >
              Tech Ledger
            </h2>
            <p class="mt-3 text-warm-600 dark:text-warm-400">
              Ein sachlicher Index meiner Kerntechnologien.
            </p>
          </div>
          <div class="divide-y divide-warm-200 dark:divide-warm-800">
            {
              skillRows.map((row) => (
                <div class="grid grid-cols-1 divide-y divide-warm-200 dark:divide-warm-800 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
                  {row.map((skill) => (
                    <a
                      href={skill.href}
                      class="ledger-hover-cell flex items-center justify-between px-4 py-3 text-sm font-semibold text-warm-900 dark:text-warm-100"
                    >
                      {skill.label}
                      <span class="ledger-hover-arrow">→</span>
                    </a>
                  ))}
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <ClientWorkRails lang="de" />

    <AppIconShowcase lang="de" />

    <section class="mt-16 animate-fade-in-up opacity-0 stagger-6">
      <article
        class="overflow-hidden rounded-2xl border border-warm-200 bg-white shadow-sm dark:border-warm-800 dark:bg-dark-surface dark:shadow-2xl dark:shadow-black/30"
      >
        <div class="grid gap-0 lg:grid-cols-[1fr_18rem]">
          <div class="p-5 sm:p-6">
            <p
              class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600 dark:text-accent-300"
            >
              Highlight: eigenes Projekt
            </p>
            <h2
              class="mt-3 text-2xl font-display font-bold tracking-tight text-warm-900 dark:text-white"
            >
              Nürnberg Maps Review Removals
            </h2>
            <p class="mt-3 max-w-2xl text-warm-600 dark:text-warm-400">
              Lokales Datenprojekt zur Analyse von Löschhinweisen bei
              Google-Maps-Bewertungen in Nürnberg.
            </p>
          </div>
          <div
            class="grid grid-cols-2 border-t border-warm-200 dark:border-warm-800 lg:border-l lg:border-t-0"
          >
            <a
              href="https://nuernberg-maps-review-removals.patwoz.dev/"
              target="_blank"
              rel="noreferrer"
              class="ledger-hover-cell flex min-h-28 flex-col justify-between border-r border-warm-200 p-4 dark:border-warm-800"
            >
              <span
                class="ledger-hover-kicker text-[10px] font-semibold uppercase tracking-[0.2em] text-warm-500 dark:text-warm-600"
              >
                Öffnen
              </span>
              <span
                class="flex items-center justify-between text-sm font-bold text-warm-900 dark:text-white"
              >
                Website
                <span class="ledger-hover-arrow">→</span>
              </span>
            </a>
            <a
              href="https://github.com/patlux/nuernberg-maps-review-removals"
              target="_blank"
              rel="noreferrer"
              class="ledger-hover-cell flex min-h-28 flex-col justify-between p-4"
            >
              <span
                class="ledger-hover-kicker text-[10px] font-semibold uppercase tracking-[0.2em] text-warm-500 dark:text-warm-600"
              >
                Öffnen
              </span>
              <span
                class="flex items-center justify-between text-sm font-bold text-warm-900 dark:text-white"
              >
                GitHub
                <span class="ledger-hover-arrow">→</span>
              </span>
            </a>
          </div>
        </div>
      </article>
    </section>

    <section
      class="mt-16 animate-fade-in-up opacity-0 stagger-7 p-6 card-soft bg-gradient-to-br from-warm-50 to-warm-100 dark:from-dark-surface dark:to-dark-elevated"
    >
      <div class="flex items-start gap-4">
        <div
          class="w-12 h-12 flex items-center justify-center bg-warm-200 dark:bg-warm-800/30 rounded-xl flex-shrink-0"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="w-6 h-6 text-accent-600 dark:text-accent-400"
          >
            <path
              fill-rule="evenodd"
              d="M8.25 6.75a3.75 3.75 0 117.5 0 3.75 3.75 0 01-7.5 0zM15.75 9.75a3 3 0 116 0 3 3 0 01-6 0zM2.25 9.75a3 3 0 116 0 3 3 0 01-6 0zM6.31 15.117A6.745 6.745 0 0112 12a6.745 6.745 0 016.709 7.498.75.75 0 01-.372.568A12.696 12.696 0 0112 21.75c-2.305 0-4.47-.612-6.337-1.684a.75.75 0 01-.372-.568 6.787 6.787 0 011.019-4.38z"
              clip-rule="evenodd"></path>
            <path
              d="M5.082 14.254a8.287 8.287 0 00-1.308 5.135 9.687 9.687 0 01-1.764-.44l-.115-.04a.563.563 0 01-.373-.487l-.01-.121a3.75 3.75 0 013.57-4.047zM20.226 19.389a8.287 8.287 0 00-1.308-5.135 3.75 3.75 0 013.57 4.047l-.01.121a.563.563 0 01-.373.486l-.115.04c-.567.2-1.156.349-1.764.441z"
            ></path>
          </svg>
        </div>
        <div class="flex-1">
          <h3
            class="font-display text-xl font-semibold text-warm-900 dark:text-warm-100"
          >
            piparo.tech
          </h3>
          <p class="text-warm-600 dark:text-warm-400 mt-2 leading-relaxed">
            Gemeinsam mit zwei Kollegen baue ich auch <a
              href="https://piparo.tech"
              class="text-accent-600 dark:text-accent-400 font-medium hover:text-accent-700 dark:hover:text-accent-300 border-b border-accent-300 dark:border-accent-600"
              >piparo.tech</a
            > auf, ein IT-Dienstleister mit Fokus auf passgenaue Lösungen für die
            spezifischen Technologiebedürfnisse unserer Kunden.
          </p>
          <a
            href="mailto:info@piparo.tech"
            class="inline-flex items-center gap-2 mt-4 text-sm font-medium text-accent-600 dark:text-accent-400 hover:text-accent-700 dark:hover:text-accent-300 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="w-4 h-4"
            >
              <path
                d="M3 4a2 2 0 00-2 2v1.161l8.441 4.221a1.25 1.25 0 001.118 0L19 7.162V6a2 2 0 00-2-2H3z"
              ></path>
              <path
                d="M19 8.839l-7.77 3.885a2.75 2.75 0 01-2.46 0L1 8.839V14a2 2 0 002 2h14a2 2 0 002-2V8.839z"
              ></path>
            </svg>
            info@piparo.tech
          </a>
        </div>
      </div>
    </section>

    <Footer />
  </BaseLayout>
</Layout>
